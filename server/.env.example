# Backend environment variables
PORT=3001

# Comma-separated list of allowed CORS origins.
# Defaults to notify.stanleyowen.com, ntust.netlify.app, and localhost if omitted.
ALLOWED_ORIGINS=https://notify.stanleyowen.com,https://ntust.netlify.app

# Comma-separated email addresses that are allowed to poll as fast as 1 s.
# All other users are rate-limited to a minimum of 10 s.
AUTH_EMAILS=you@example.com,other@example.com

# Number of reverse-proxy hops in front of this server (nginx, Caddy,
# Cloudflare, …). Used to resolve the real client IP for rate limiting.
# Set to 0 if clients connect to this server directly — otherwise clients
# can spoof X-Forwarded-For to bypass per-IP rate limits.
TRUST_PROXY=1

# How many watched courses the notification poll loop fetches from NTUST at
# once. Higher = faster cycles when many distinct courses are watched, but more
# simultaneous load on NTUST. Default 8.
POLL_FETCH_CONCURRENCY=8

# ── Firebase Admin SDK ──────────────────────────────────────────────────────
# Option A: path to downloaded service-account JSON file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Option B: paste the entire service-account JSON as a single-line string
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Email (SMTP) ────────────────────────────────────────────────────────────
# Example using Gmail with an App Password:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="NTUST Tracker <you@gmail.com>"
